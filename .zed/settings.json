{
  "languages": {
    "Rust": {
      "language_servers": ["...", "tailwindcss-language-server"]
    }
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "rustfmt": {
          "overrideCommand": [
            "sh",
            "-c",
            "set -o pipefail; dx fmt -f - | rustfmt"
          ]
        }
      }
    },
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "rust": "html"
        },
        "experimental": {
          "classRegex": ["class: \"(.*)\""],
          "configFile": "assets/main.css"
        }
      }
    }
  }
}
